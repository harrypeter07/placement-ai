TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=+91xxxxxxxxxx
# Example: FreeKaaMaal = -1001179165333 | RCOEM CDPC 2027 = -1003268872994
TELEGRAM_GROUP_IDS=-1001179165333
GEMINI_API_KEY=your_gemini_key
# Include /placemint in URI, OR set MONGODB_DB_NAME (used when URI ends with /?appName=...)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/placemint?retryWrites=true&w=majority
MONGODB_DB_NAME=placemint
WEB_APP_URL=http://localhost:3000
TELEGRAM_WORKER_SECRET=your_shared_secret_same_as_web_env
SESSION_NAME=placemint_session
# Log messages only — no save to DB, no API ingest (safe for testing)
TELEGRAM_READ_ONLY=true
# Recent messages to backfill into Notifications on worker start
TELEGRAM_HISTORY_LIMIT=40
